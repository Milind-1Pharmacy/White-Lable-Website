{
  "version": "1.0.0",
  "mode": "single-tenant",

  "architecture": {
    "rules": [
      "Never hardcode business content in components",
      "All content, branding, and features must come from app_master.json",
      "Components must be stateless and reusable",
      "Compliance rules override UI rendering",
      "App must render safely even with partial/missing config"
    ]
  },

  "routing": {
    "requiredPages": [
      "/",
      "/about",
      "/services",
      "/contact",
      "/privacy-policy",
      "/terms-and-conditions",
      "/disclaimer"
    ],
    "fallback": "/not-found"
  },

  "rendering": {
    "default": "server-component",
    "strategy": "ssr+isr",
    "revalidateSeconds": 3600
  },

  "sectionAllowlist": [
    "hero",
    "about",
    "services",
    "features",
    "howItWorks",
    "gallery",
    "stats",
    "testimonials",
    "faq",
    "heroBanner",
    "heroRotating",
    "appDownload",
    "aboutWithStats",
    "servicesIconRow",
    "brandOptionsCompare",
    "videoFeature",
    "mediaSplit",
    "productPromo",
    "teamGrid",
    "aboutFeatures",
    "savingsVideo",
    "teamShowcase"
  ],

  "sectionMapping": {
    "hero": "modules/Hero.tsx",
    "about": "modules/About.tsx",
    "services": "modules/Services.tsx",
    "features": "modules/Features.tsx",
    "howItWorks": "modules/HowItWorks.tsx",
    "gallery": "modules/Gallery.tsx",
    "stats": "modules/Stats.tsx",
    "testimonials": "modules/Testimonials.tsx",
    "faq": "modules/Faq.tsx",
    "heroBanner": "modules/HeroBanner.tsx",
    "heroRotating": "modules/HeroRotating.tsx",
    "appDownload": "modules/AppDownload.tsx",
    "aboutWithStats": "modules/AboutWithStats.tsx",
    "servicesIconRow": "modules/ServicesIconRow.tsx",
    "brandOptionsCompare": "modules/BrandOptionsCompare.tsx",
    "videoFeature": "modules/VideoFeature.tsx",
    "mediaSplit": "modules/MediaSplit.tsx",
    "productPromo": "modules/ProductPromo.tsx",
    "teamGrid": "modules/TeamGrid.tsx",
    "aboutFeatures": "modules/AboutFeatures.tsx",
    "savingsVideo": "modules/SavingsVideo.tsx",
    "teamShowcase": "modules/TeamShowcase.tsx"
  },

  "compliance": {
    "defaultMode": "business-profile-safe",
    "rules": [
      "Replace unsafe CTA labels automatically",
      "Disable payment/cart features if enabled",
      "Ensure disclaimer is always present",
      "Prevent rendering of restricted sections",
      "Force support-only communication flows"
    ],
    "unsafeCtaLabels": [
      "Buy Now",
      "Order",
      "Order Now",
      "Checkout",
      "Add to Cart",
      "Pay",
      "Pay Now",
      "Subscribe & Pay"
    ],
    "safeCtaFallback": "Learn More",
    "forceDisabledFeatures": [
      "enablePayments",
      "enableCart"
    ],
    "defaultDisclaimer": "The information presented on this website is for general informational purposes only and should not be relied upon as professional advice."
  },

  "performance": {
    "rules": [
      "Use ISR for static pages",
      "Minimize client-side JS",
      "Tree-shake unused components",
      "Enable image optimization",
      "Use CDN-ready assets"
    ]
  },

  "branding": {
    "fallbackColors": {
      "primary": "#111827",
      "secondary": "#6B7280",
      "background": "#FFFFFF",
      "text": "#111827",
      "accent": "#1F1E1B",
      "ink": "#0F0E0C",
      "warm": "#E63950",
      "cool": "#1FB6B6"
    }
  }
}
