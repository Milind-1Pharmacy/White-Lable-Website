{
  "name": "whitelabel-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:site": "npm run dev --workspace apps/site",
    "dev:builder": "npm run dev --workspace apps/builder",
    "build:site": "npm run build --workspace apps/site",
    "build:builder": "npm run build --workspace apps/builder",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
